<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Vinichy Suite" verbose="1" parallel="tests" thread-count="4">

    <listeners>
        <listener class-name="common.ScreenshotListener"/>
        <listener class-name="common.ExtentListener"/>
        <listener class-name="common.AllureListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="1. LoginTests and LogoutTests">
        <classes>
            <class name="testcases.LoginTests"/>
            <class name="testcases.LogoutTests"/>
        </classes>
    </test>

    <test name="2. CartTests">
        <classes>
            <class name="testcases.CartTests"/>
        </classes>
    </test>

    <test name="3. DeliveryInfoTests">
        <classes>
            <class name="testcases.DeliveryInfoTests"/>
        </classes>
    </test>

    <test name="4. OrderTests">
        <classes>
            <class name="testcases.OrderTests"/>
        </classes>
    </test>

</suite>
